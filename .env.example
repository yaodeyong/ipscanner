# 服务端口（可选，默认 3001）
# PORT=3001

# SQLite 数据库文件路径（可选，默认 backend/data/ipscanner.db）
# DB_PATH=./backend/data/ipscanner.db

# ---------- 扫描（尽量多发现 MAC / 减少误判离线）----------
# 单次 ping 等待毫秒数（默认 800；慢网或 WiFi 可试 1200～2000）
# SCAN_PING_TIMEOUT_MS=1200
# 额外要预热的 /24 前三段，逗号分隔（与本机网卡前缀合并），例：192.168.10
# SCAN_SUBNET_PREFIXES=192.168.10
# 每批并发 ping 数（默认 24；丢包多可改为 16）
# SCAN_PING_BATCH_SIZE=16
# 设为 1 则跳过整网段 ping（最快，MAC 最少）
# SCAN_SKIP_WARM=0
